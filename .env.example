# --- Obrigatório ---
# PostgreSQL (ex.: Neon). Use SSL em produção.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Login com Google: defina AUTH_ENABLED=true e preencha AUTH_SECRET + OAuth abaixo.
# Sem AUTH_ENABLED, a app roda em modo local (um usuário dev no banco, sem tela de login).
# AUTH_ENABLED="true"

# Auth.js: openssl rand -base64 32 (obrigatório quando AUTH_ENABLED=true)
AUTH_SECRET=""

# Google OAuth (Console → Credenciais → ID cliente OAuth aplicativo Web)
# Redirect URI dev:     http://localhost:3000/api/auth/callback/google
# Redirect URI prod:    https://<seu-projeto>.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Ingestão de mercado (FRED + Yahoo) ---
# Chave gratuita: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=""
# Segredo para GET /api/cron/* (ingest-market, qi-macro, qi-prices, qi-regime, qi-sectors, qi-recommend, qi-pipeline). Bearer.
CRON_SECRET=""

# --- Quantitative intelligence (Python `analytics/`) ---
# POLYGON_API_KEY=""
# FMP_API_KEY=""
# QI_MODEL_VERSION="v0.1.0"
# QI_RUN_PYTHON="true"
# QI_PYTHON_BIN="python3"
# QI_JOB="all"
# QI_POLYGON_MAX_ASSETS="40"
# QI_UNIVERSE_MAX_PER_SECTOR="120"
# QI_AS_OF_DATE="2026-04-01"

# --- Opcional ---
# URL canônica do app (útil se o callback OAuth falhar na Vercel)
# AUTH_URL="https://seu-projeto.vercel.app"
