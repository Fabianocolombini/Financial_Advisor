# PostgreSQL (ex.: Neon) — use a URL com SSL em produção
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth.js — gere com: openssl rand -base64 32
AUTH_SECRET=""

# OAuth Google — Console Google Cloud → credenciais OAuth 2.0
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Opcional: URL pública do app (Vercel preenche em deploy)
# AUTH_URL="https://seu-dominio.vercel.app"

# Neon: para migrate com pooler, alguns guias usam DIRECT_URL apontando ao host direto.
# Este projeto usa só DATABASE_URL no Prisma; use a connection string "direct" do Neon para migrate se o pooler falhar.
